generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
  REFUNDED
}

enum Currency {
  KRW
  USD
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id             Int       @id @default(autoincrement())
  name           String
  phone          String
  email          String    @unique
  password       String
  address        String?
  address_detail String?
  role           UserRole  @default(USER)
  created_at     DateTime? @default(now())
  updated_at     DateTime? @updatedAt
  deleted_at     DateTime?

  orders         Order[]

  @@map("user")
}

model Order {
  id             Int          @id @default(autoincrement())
  user_id        Int
  idempotency_key String @unique
  paymentKey     String?
  status          OrderStatus  @default(PENDING)
  total_price    Int
  currency        Currency     @default(KRW)
  address        String?
  address_detail String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  approved_at    DateTime?
  deleted_at     DateTime?
  user           User         @relation(fields: [user_id], references: [id])
  order_infos    OrderInfo[]

  @@map("order")
}

model OrderInfo {
  id          Int       @id @default(autoincrement())
  order_id    Int
  product_info_id Int       // ProductInfo 연결 (어떤 옵션인지 추적)
  snapshot_price  Int       // 주문 시점 가격 스냅샷
  amount          Int       @default(1)
  currency    Currency @default(KRW)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  order        Order       @relation(fields: [order_id], references: [id])
  product_info ProductInfo @relation(fields: [product_info_id], references: [id])

  @@map("order_info")
}

model Stock {
  id              Int      @id @default(autoincrement())
  product_info_id Int      @unique
  qty             Int      @default(0)
  version         Int      @default(0) 
  updated_at      DateTime @updatedAt

  product_info ProductInfo @relation(fields: [product_info_id], references: [id])

  @@map("stock")
}

model Product {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?       @db.Text
  image_url     String?       @db.Text
  thumb_url     String?       @db.Text
  code          String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  deleted_at    DateTime?

  product_infos ProductInfo[]

  @@map("product")
}

model ProductInfo {
  id            Int            @id @default(autoincrement())
  product_id    Int
  name          String?        // 옵션명 (예: "블랙 M", "화이트 L")
  price         Int
  currency      Currency       @default(KRW)
  discount_rate Int            @default(0)
  status        ProductStatus  @default(INACTIVE)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  deleted_at    DateTime?

  product       Product        @relation(fields: [product_id], references: [id])
  stock       Stock?
  order_infos OrderInfo[]

  @@map("product_info")
}
